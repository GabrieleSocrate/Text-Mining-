","            output_dim=embed_dim,\n","            weights=[embedding_matrix],\n","            trainable=False,\n","            mask_zero=True\n","        ),\n","        SpatialDropout1D(dropout_rate),\n","        Bidirectional(LSTM(lstm_units, dropout=dropout_rate)),\n","        Dense(dense_units),\n","        LeakyReLU(negative_slope=0.1),\n","        Dropout(dropout_rate),\n","        Dense(3, activation=\"softmax\")\n","    ])\n","\n","    model.compile(\n","        optimizer=tf.keras.optimizers.Adam(learning_rate=learning_rate),\n","        loss=sparse_focal_loss(gamma=2.0, alpha=0.25),\n","        metrics=[\"accuracy\"]\n","    )\n","\n","    model.build(input_shape=(None, max_sequence_len))\n","    return model"],"metadata":{"id":"5TEq7ZKskxmB","executionInfo":{"status":"ok","timestamp":1773072421795,"user_tz":-60,"elapsed":5,"user":{"displayName":"Gabriele Trentin","userId":"18407824855460385509"}}},"execution_count":16,"outputs":[]},{"cell_type":"markdown","source":["# Model architecture over"],"metadata":{"id":"kaig_ABJyBzI"}},{"cell_type":"code","source":["# evidenziare layer del modello\n","reference_model = build_bilstm_model(\n","    vocab_size=VOCAB_SIZE,\n","    embed_dim=EMBED_DIM,\n","    embedding_matrix=embedding_matrix,\n","    max_sequence_len=MAX_SEQUENCE_LEN,\n","    lstm_units=64,\n","    dense_units=64,\n","    dropout_rate=0.3,\n","    learning_rate=1e-3\n",")\n","\n","reference_model.summary()"],"metadata":{"id":"L0xS7zOMyAv3","colab":{"base_uri":"https://localhost:8080/","height":380},"executionInfo":{"status":"ok","timestamp":1773072436612,"user_tz":-60,"elapsed":3058,"user":{"displayName":"Gabriele Trentin","userId":"18407824855460385509"}},"outputId":"73ec5b9a-7bac-4317-e1f6-23c6c534305d"},"execution_count":17,"outputs":[{"output_type":"display_data","data":{"text/plain":["\u001b[1mModel: \"sequential\"\u001b[0m\n"],"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',con